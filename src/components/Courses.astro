---
import courses from '../data/courses.json';
---

<section id="courses" style="padding:160px 80px;background:var(--pr-paper);color:var(--pr-paper-ink);">
  <div style="max-width:1760px;margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:80px;">
      <div>
        <div class="pr-section-tag" style="color:#3a3a3a;">[02] КУРСЫ</div>
        <h2 style="font-size:120px;margin-top:24px;color:#0A0A0A;">
          ВЫБЕРИ <br />СВОЙ ТЕМП.
        </h2>
      </div>
      <div style="max-width:360px;font-size:16px;line-height:1.5;color:#3a3a3a;padding-bottom:12px;">
        Все три программы дают одно и то же удостоверение. Различаются только тем, сколько часов вы хотите за рулём — и сколько комфорта.
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:24px;">
      {courses.map((c, i) => (
        <article style={`background:${c.vip ? 'var(--pr-black)' : c.accent ? 'var(--pr-yellow)' : '#fff'};color:${c.vip ? '#fff' : '#0A0A0A'};border-radius:var(--pr-r-xl);padding:36px 32px 32px;border:${c.accent ? 'none' : '1px solid rgba(0,0,0,0.08)'};position:relative;display:flex;flex-direction:column;`}>
          {c.accent && (
            <div style="position:absolute;top:-16px;left:24px;background:#0A0A0A;color:var(--pr-yellow);padding:6px 14px;border-radius:999px;font-size:11px;font-weight:800;letter-spacing:0.1em;">
              {c.tag}
            </div>
          )}
          {!c.accent && (
            <div class="pr-num" style={`color:${c.vip ? 'var(--pr-yellow)' : '#7a7a7a'};`}>0{i + 1} · {c.tag}</div>
          )}

          <h3 style={`font-size:64px;margin-top:${c.accent ? 32 : 16}px;margin-bottom:20px;line-height:0.9;letter-spacing:-0.01em;`}>
            {c.title}
          </h3>

          <p style={`font-size:16px;line-height:1.5;margin-bottom:32px;opacity:${c.vip ? 0.8 : 0.7};min-height:72px;`}>
            {c.pitch}
          </p>

          <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px;">
            <span style="font-family:var(--pr-display);font-size:56px;letter-spacing:-0.01em;">{c.price}</span>
            <span style="font-size:22px;opacity:0.6;">₽</span>
          </div>
          <div style={`font-family:var(--pr-mono);font-size:11px;letter-spacing:0.12em;color:${c.vip ? 'var(--pr-yellow)' : c.accent ? '#3a1a00' : '#7a7a7a'};margin-bottom:28px;`}>
            {c.hours}
          </div>

          <ul style="list-style:none;padding:0;margin:0 0 32px;display:grid;gap:12px;flex:1;">
            {c.features.map((f) => (
              <li style="display:flex;gap:12px;align-items:flex-start;font-size:15px;line-height:1.4;">
                <span style={`flex-shrink:0;margin-top:7px;width:6px;height:6px;border-radius:2px;background:${c.vip ? 'var(--pr-yellow)' : c.accent ? '#0A0A0A' : 'var(--pr-yellow-deep)'};`}></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <button
            type="button"
            data-pr-enroll-trigger
            data-course={c.title}
            style={`background:${c.vip ? 'var(--pr-yellow)' : '#0A0A0A'};color:${c.vip ? '#0A0A0A' : c.accent ? 'var(--pr-yellow)' : '#fff'};border:0;border-radius:999px;padding:18px 24px;font-weight:800;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;display:flex;justify-content:space-between;align-items:center;`}
          >
            <span>Выбрать</span>
            <span>→</span>
          </button>
        </article>
      ))}
    </div>
  </div>
</section>
