---
import courses from '../data/courses.json';
---

<section id="courses" class="px-5 py-[50px] md:px-20 md:py-40 bg-pr-paper text-[var(--pr-paper-ink)]">
  <div class="max-w-[1760px] mx-auto">
    <div class="md:flex md:items-end md:justify-between md:mb-20">
      <div>
        <div class="pr-section-tag text-[10px] md:text-[11px]" style="color:#3a3a3a;">[02] КУРСЫ</div>
        <h2 class="font-display uppercase text-[clamp(40px,12vw,56px)] md:text-[120px] leading-[0.9] -tracking-[0.01em] mt-3.5 md:mt-6 text-pr-black">
          ВЫБЕРИ <br />СВОЙ ТЕМП.
        </h2>
      </div>
      <p class="mt-3.5 md:mt-0 mb-7 md:mb-3 max-w-[360px] text-sm md:text-base leading-[1.5] text-[#3a3a3a]">
        Все три программы дают одно и то же удостоверение. Различаются только тем, сколько часов вы хотите за рулём — и сколько комфорта.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {courses.map((c, i) => (
        <article
          class:list={[
            'rounded-[22px] md:rounded-[var(--pr-r-xl)] p-6 md:p-8 md:pt-9 relative flex flex-col',
            c.vip ? 'bg-pr-black text-white' : c.accent ? 'bg-pr-yellow text-pr-black' : 'bg-white text-pr-black border border-black/[0.08]',
          ]}
        >
          {c.accent ? (
            <div class="absolute -top-2.5 md:-top-4 left-5 md:left-6 bg-pr-black text-pr-yellow px-2.5 md:px-3.5 py-1 md:py-1.5 rounded-full text-[9px] md:text-[11px] font-extrabold tracking-[0.1em]">
              {c.tag}
            </div>
          ) : (
            <div class="pr-num text-[9px] md:text-[11px]" style={`color:${c.vip ? 'var(--pr-yellow)' : '#7a7a7a'};`}>0{i + 1} · {c.tag}</div>
          )}

          <h3
            class="font-display uppercase text-[40px] md:text-[64px] leading-[0.9] -tracking-[0.01em] mb-4 md:mb-5"
            class:list={[c.accent ? 'mt-3.5 md:mt-8' : 'mt-2 md:mt-4']}
          >
            {c.title}
          </h3>

          <p class="text-[13px] md:text-base leading-[1.5] mb-4 md:mb-8" style={`opacity:${c.vip ? 0.8 : 0.7};min-height:0;`}>
            {c.pitch}
          </p>

          <div class="flex items-baseline gap-1 md:gap-1.5 mb-1 md:mb-2 whitespace-nowrap">
            <span class="font-display text-[38px] md:text-[56px] -tracking-[0.01em]">{c.price}</span>
            <span class="text-base md:text-[22px] opacity-60">₽</span>
          </div>
          <div
            class="font-mono text-[9px] md:text-[11px] tracking-[0.12em] mb-4 md:mb-7"
            style={`color:${c.vip ? 'var(--pr-yellow)' : c.accent ? '#3a1a00' : '#7a7a7a'};`}
          >
            {c.hours}
          </div>

          <ul class="list-none p-0 m-0 mb-4 md:mb-8 grid gap-2 md:gap-3 flex-1">
            {c.features.map((f) => (
              <li class="flex gap-3 items-start text-[13px] md:text-[15px] leading-[1.4]">
                <span
                  class="flex-shrink-0 mt-[7px] w-1.5 h-1.5 rounded-[2px]"
                  style={`background:${c.vip ? 'var(--pr-yellow)' : c.accent ? '#0A0A0A' : 'var(--pr-yellow-deep)'};`}
                ></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <button
            type="button"
            data-pr-enroll-trigger
            data-course={c.title}
            class:list={[
              'w-full border-0 rounded-full py-3.5 md:py-[18px] px-5 md:px-6 font-extrabold text-[12px] md:text-[13px] tracking-[0.08em] uppercase cursor-pointer flex justify-between items-center',
              c.vip ? 'bg-pr-yellow text-pr-black' : c.accent ? 'bg-pr-black text-pr-yellow' : 'bg-pr-black text-white',
            ]}
          >
            <span>Выбрать</span>
            <span>→</span>
          </button>
        </article>
      ))}
    </div>
  </div>
</section>
