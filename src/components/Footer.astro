---
const socials = ['VK', 'TG', 'INST', 'YT'];
---

<footer style="background:var(--pr-black);border-top:1px solid var(--pr-line);padding:100px 80px 60px;">
  <div style="max-width:1760px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;padding-bottom:60px;border-bottom:1px solid var(--pr-line);">
      <div style="font-family:var(--pr-display);font-size:240px;line-height:0.85;letter-spacing:-0.02em;color:var(--pr-yellow);">
        ПРАЙД
      </div>
      <div style="text-align:right;">
        <div class="pr-num">КРАСНОЯРСК</div>
        <div style="font-family:var(--pr-display);font-size:36px;margin-top:12px;">
          МАСТЕРСТВО<br />НАЧИНАЕТСЯ ЗДЕСЬ.
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:40px;padding:60px 0;">
      <div>
        <div class="pr-num" style="margin-bottom:14px;">КОНТАКТЫ</div>
        <div style="font-size:15px;line-height:1.7;">
          ул. Ленина, 78<br />
          660049, Красноярск<br />
          <a href="tel:+73912345678">+7 (391) 234-56-78</a><br />
          <a href="mailto:hello@pride-school.ru">hello@pride-school.ru</a>
        </div>
      </div>
      <div>
        <div class="pr-num" style="margin-bottom:14px;">РЕЖИМ РАБОТЫ</div>
        <div style="font-size:15px;line-height:1.7;color:var(--pr-mute-2);">
          Пн–Пт · 09:00–21:00<br />
          Сб · 10:00–18:00<br />
          Вс · по записи
        </div>
      </div>
      <div>
        <div class="pr-num" style="margin-bottom:14px;">ССЫЛКИ</div>
        <div style="font-size:15px;line-height:1.9;">
          <a class="pr-link-u" href="#courses">Курсы и цены</a><br />
          <a class="pr-link-u" href="#instructors">Инструкторы</a><br />
          <a class="pr-link-u" href="#reviews">Отзывы</a><br />
          <a class="pr-link-u" href="#faq">Частые вопросы</a>
        </div>
      </div>
      <div>
        <div class="pr-num" style="margin-bottom:14px;">СОЦСЕТИ</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          {socials.map((s) => (
            <a href="#" style="width:48px;height:48px;border-radius:999px;border:1px solid var(--pr-line-strong);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;">{s}</a>
          ))}
        </div>
      </div>
    </div>

    <div style="padding-top:30px;border-top:1px solid var(--pr-line);display:flex;justify-content:space-between;font-size:12px;color:var(--pr-mute);font-family:var(--pr-mono);letter-spacing:0.06em;">
      <span>© 2026 ООО АВТОШКОЛА «ПРОФИ»</span>
      <span>ЛИЦЕНЗИЯ № 7167-Л</span>
      <span>ИНН 2466154321</span>
      <span>ПОЛИТИКА КОНФИДЕНЦИАЛЬНОСТИ</span>
    </div>
  </div>
</footer>
