---
const socials = ['VK', 'TG', 'INST', 'YT'];
---

<footer class="bg-pr-black border-t border-white/[0.08] px-5 pt-12 pb-7 md:px-20 md:pt-[100px] md:pb-[60px]">
  <div class="max-w-[1760px] mx-auto">
    <div class="md:flex md:items-center md:justify-between pb-7 md:pb-[60px] border-b border-white/[0.08]">
      <div class="font-display text-[80px] md:text-[240px] leading-[0.85] -tracking-[0.02em] text-pr-yellow">
        ПРАЙД
      </div>
      <div class="mt-5 md:mt-0 md:text-right">
        <div class="pr-num">КРАСНОЯРСК</div>
        <div class="font-display uppercase text-[22px] md:text-[36px] mt-2 md:mt-3 leading-[0.95]">
          МАСТЕРСТВО<br />НАЧИНАЕТСЯ ЗДЕСЬ.
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-7 md:gap-10 py-7 md:py-[60px]">
      <div>
        <div class="pr-num mb-3.5">КОНТАКТЫ</div>
        <div class="text-sm md:text-[15px] leading-[1.7]">
          ул. Ленина, 78<br />
          660049, Красноярск<br />
          <a href="tel:+73912345678">+7 (391) 234-56-78</a><br />
          <a href="mailto:hello@pride-school.ru">hello@pride-school.ru</a>
        </div>
      </div>
      <div>
        <div class="pr-num mb-3.5">РЕЖИМ РАБОТЫ</div>
        <div class="text-sm md:text-[15px] leading-[1.7] text-white/[0.65]">
          Пн–Пт · 09:00–21:00<br />
          Сб · 10:00–18:00<br />
          Вс · по записи
        </div>
      </div>
      <div>
        <div class="pr-num mb-3.5">ССЫЛКИ</div>
        <div class="text-sm md:text-[15px] leading-[1.9]">
          <a class="pr-link-u" href="#courses">Курсы и цены</a><br />
          <a class="pr-link-u" href="#instructors">Инструкторы</a><br />
          <a class="pr-link-u" href="#reviews">Отзывы</a><br />
          <a class="pr-link-u" href="#faq">Частые вопросы</a>
        </div>
      </div>
      <div>
        <div class="pr-num mb-3.5">СОЦСЕТИ</div>
        <div class="flex gap-2.5 flex-wrap">
          {socials.map((s) => (
            <a href="#" class="w-11 h-11 md:w-12 md:h-12 rounded-full border border-white/[0.18] flex items-center justify-center font-extrabold text-xs">{s}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="pt-5 md:pt-7 border-t border-white/[0.08] flex flex-col md:flex-row md:justify-between gap-1.5 md:gap-0 text-[10px] md:text-xs text-white/50 font-mono tracking-[0.06em]">
      <span>© 2026 ООО АВТОШКОЛА «ПРОФИ»</span>
      <span>ЛИЦЕНЗИЯ № 7167-Л</span>
      <span>ИНН 2466154321</span>
      <span>ПОЛИТИКА КОНФИДЕНЦИАЛЬНОСТИ</span>
    </div>
  </div>
</footer>
