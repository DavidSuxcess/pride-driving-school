---
import instructors from '../data/instructors.json';

const base = import.meta.env.BASE_URL;
---

<section id="instructors" class="px-5 py-[50px] md:px-20 md:py-40 bg-pr-black relative">
  <div class="pr-grid-bg absolute inset-0 opacity-40 pointer-events-none"></div>
  <div class="relative max-w-[1760px] mx-auto">
    <div class="md:flex md:items-end md:justify-between md:mb-20">
      <div>
        <div class="pr-section-tag text-[10px] md:text-[11px]">[03] КОМАНДА</div>
        <h2 class="font-display uppercase text-[clamp(36px,11vw,52px)] md:text-[120px] leading-[0.95] md:leading-[0.9] -tracking-[0.01em] mt-3.5 md:mt-6 text-white">
          ТРОЕ ЛЮДЕЙ,<br />
          <span class="text-pr-yellow">КОТОРЫЕ <br class="md:hidden" />НЕ КРИЧАТ.</span>
        </h2>
      </div>
      <p class="mt-3.5 md:mt-0 mb-7 md:mb-3 max-w-[360px] text-sm md:text-base leading-[1.5] text-white/[0.65]">
        <span class="md:hidden">Каждый — действующий водитель с 10+ лет стажа. Нажмите карточку, чтобы открыть профиль.</span>
        <span class="hidden md:inline">Каждый инструктор Pride — действующий водитель с 10+ лет стажа, не «сел за баранку только чтобы учить».</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {instructors.map((p, i) => (
        <article
          class="pr-lift rounded-[18px] md:rounded-[var(--pr-r-xl)] overflow-hidden border border-white/[0.08] bg-pr-graphite cursor-pointer md:cursor-default"
          data-pr-instructor-card
          data-idx={i}
        >
          <div class="relative aspect-[4/5] overflow-hidden">
            <img src={`${base}/assets/${p.img}`} alt={p.name} class="w-full h-full object-cover" />
            <div class="absolute top-3 md:top-4 left-3 md:left-4 bg-pr-yellow text-pr-black px-2.5 md:px-3 py-1 md:py-1.5 rounded-full font-mono text-[9px] md:text-[10px] tracking-[0.12em] font-bold z-[2]">
              {p.tag}
            </div>
            <div class="absolute right-3.5 md:right-5 top-2 md:top-3 font-display text-[84px] md:text-[110px] text-white leading-[0.9] -tracking-[0.04em] opacity-95" style="text-shadow:0 4px 20px rgba(0,0,0,0.6);">
              0{i + 1}
            </div>
            <div class="absolute inset-x-0 bottom-0 p-4 pt-10 md:p-5 md:pt-[60px]" style="background:linear-gradient(transparent, rgba(0,0,0,0.85));">
              <div class="font-display text-3xl md:text-[40px] leading-[0.9]">{p.name}</div>
              <div class="text-[9px] md:text-[11px] text-pr-yellow tracking-[0.18em] font-mono mt-1 md:mt-1.5">
                {p.surname}
              </div>
            </div>
          </div>

          <div class="p-4 md:p-6 md:pt-6 md:pb-7">
            <div class="text-[14px] md:text-[18px] leading-[1.4] mb-3.5 md:mb-6 border-l-2 border-pr-yellow pl-3 md:pl-4 italic">
              «{p.quote}»
            </div>
            <div class="flex flex-wrap items-center justify-between gap-1.5">
              <div class="flex flex-wrap gap-1.5 md:gap-2">
                {p.statsShort.map((s) => (
                  <span class="text-[10px] md:text-[11px] text-white/[0.65] px-2 md:px-2.5 py-1 md:py-[5px] border border-white/[0.18] rounded-full tracking-[0.04em]">{s}</span>
                ))}
              </div>
              <span class="md:hidden text-[11px] text-pr-yellow font-bold tracking-[0.04em]">ПРОФИЛЬ →</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
