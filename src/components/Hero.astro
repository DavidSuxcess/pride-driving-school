---
import PrLion from './PrLion.astro';
import reviews from '../data/reviews.json';

const reviewsCount = reviews.length;
---

<section class="relative overflow-hidden bg-pr-black">
  <div class="pr-grid-bg absolute inset-0 opacity-50 md:opacity-60"></div>

  <div class="pr-tape absolute -right-[60px] top-[30px] w-[220px] h-9 -rotate-[8deg] md:right-[-100px] md:top-20 md:w-[380px] md:h-[60px]"></div>
  <div class="pr-tape-thin hidden md:block absolute right-[-50px] top-[170px] w-[220px] h-7 -rotate-[8deg]"></div>

  <div class="absolute right-[-60px] top-[100px] opacity-[0.07] pointer-events-none md:top-[220px] md:opacity-[0.06]">
    <span class="block md:hidden"><PrLion size={360} color="#E45400" /></span>
    <span class="hidden md:block"><PrLion size={780} color="#E45400" /></span>
  </div>

  <div class="relative z-10 max-w-[1760px] mx-auto px-5 pt-10 pb-9 md:px-20 md:pt-[140px] md:pb-[120px]">
    <div class="hidden md:flex items-center gap-4 mb-10">
      <div class="h-px flex-1 bg-white/10"></div>
    </div>

    <h1
      class="font-display uppercase text-white text-[76px] md:text-[220px] leading-[0.85] md:leading-[0.82] -tracking-[0.02em] mb-6 md:mb-10 font-normal whitespace-nowrap md:whitespace-normal"
    >
      ВОДИ<br />
      <span class="text-pr-yellow">УВЕРЕННО.</span>
      <span class="hidden md:inline-flex items-center gap-6 align-middle">
        <span class="font-text normal-case font-semibold -tracking-[0.01em] text-white max-w-[380px] border-l-[3px] border-pr-yellow pl-5 leading-[1.15] text-[44px]">
          Не «сдай экзамен», а реально <em class="not-italic bg-pr-yellow text-pr-black px-1">научись водить</em>.
        </span>
      </span>
    </h1>

    <div class="md:hidden text-base leading-[1.4] text-white max-w-[320px] border-l-[3px] border-pr-yellow pl-3.5 mb-7">
      Не «сдай экзамен», а реально <span class="pr-mark">научись водить</span>.
    </div>

    <div class="grid gap-2.5 md:flex md:items-center md:gap-5 md:mt-16">
      <button
        type="button"
        data-pr-enroll-trigger
        class="pr-btn-yellow w-full md:w-auto justify-between md:justify-start"
        style="padding:18px 22px;font-size:14px;"
      >
        Записаться на курс <span class="text-lg md:text-xl">→</span>
      </button>
      <button
        type="button"
        class="pr-btn-ghost w-full md:w-auto"
        style="padding:14px 22px;font-size:13px;"
      >
        ▶ Как проходит занятие · 1 мин
      </button>

      <div class="md:hidden mt-3 px-4 py-3.5 border border-white/[0.18] rounded-[14px] flex items-center justify-between">
        <div class="pr-num text-[9px]">ОТЗЫВЫ НА АВИТО</div>
        <div class="flex items-center gap-1.5">
          <span class="text-pr-yellow text-[13px] tracking-[1px]">★★★★★</span>
          <span class="text-base font-extrabold">5.0</span>
          <span class="text-white/50 text-[11px]">· {reviewsCount}+</span>
        </div>
      </div>

      <div class="hidden md:block ml-auto text-right">
        <div class="pr-num">ОТЗЫВЫ НА АВИТО</div>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-pr-yellow text-lg tracking-[2px]">★★★★★</span>
          <span class="text-[22px] font-extrabold">5.0</span>
          <span class="text-white/50 text-[13px]">· {reviewsCount}+ отзывов</span>
        </div>
      </div>
    </div>
  </div>

  <div class="h-1 relative overflow-hidden">
    <div class="pr-road absolute inset-0 opacity-60" style="background-size:40px 4px;"></div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    section .pr-road { background-size: 56px 4px !important; }
  }
</style>
