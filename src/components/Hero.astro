---
import PrLion from './PrLion.astro';
import reviews from '../data/reviews.json';

const reviewsCount = reviews.length;
---

<section style="position:relative;overflow:hidden;background:var(--pr-black);">
  <div class="pr-grid-bg" style="position:absolute;inset:0;opacity:0.6;"></div>
  <div class="pr-tape" style="position:absolute;right:-100px;top:80px;width:380px;height:60px;transform:rotate(-8deg);"></div>
  <div class="pr-tape-thin" style="position:absolute;right:-50px;top:170px;width:220px;height:28px;transform:rotate(-8deg);"></div>

  <div style="position:absolute;right:-60px;top:220px;opacity:0.06;pointer-events:none;">
    <PrLion size={780} color="#E45400" />
  </div>

  <div style="max-width:1760px;margin:0 auto;padding:140px 80px 120px;position:relative;z-index:1;">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:40px;">
      <div style="height:1px;flex:1;background:rgba(255,255,255,0.1);"></div>
    </div>

    <h1 style="font-size:220px;line-height:0.82;letter-spacing:-0.02em;margin-bottom:40px;font-weight:400;">
      ВОДИ<br />
      <span style="display:inline-flex;align-items:center;gap:24px;">
        <span style="color:var(--pr-yellow);">УВЕРЕННО.</span>
        <span style="font-size:44px;font-family:var(--pr-text);text-transform:none;font-weight:600;letter-spacing:-0.01em;color:#fff;max-width:380px;border-left:3px solid var(--pr-yellow);padding-left:20px;line-height:1.15;">
          Не «сдай экзамен», а реально <em style="font-style:normal;background:var(--pr-yellow);color:#000;padding:0 4px;">научись водить</em>.
        </span>
      </span>
    </h1>

    <div style="display:flex;align-items:center;gap:20px;margin-top:64px;">
      <button type="button" data-pr-enroll-trigger class="pr-btn-yellow" style="padding:22px 36px;font-size:15px;">
        Записаться на курс <span style="font-size:20px;">→</span>
      </button>
      <button type="button" class="pr-btn-ghost" style="padding:20px 28px;">
        ▶ Как проходит занятие · 1 мин
      </button>
      <div style="margin-left:auto;text-align:right;">
        <div class="pr-num">ОТЗЫВЫ НА АВИТО</div>
        <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
          <span style="color:var(--pr-yellow);font-size:18px;letter-spacing:2px;">★★★★★</span>
          <span style="font-size:22px;font-weight:800;">5.0</span>
          <span style="color:var(--pr-mute);font-size:13px;">· {reviewsCount}+ отзывов</span>
        </div>
      </div>
    </div>
  </div>

  <div style="height:4px;position:relative;overflow:hidden;">
    <div class="pr-road" style="position:absolute;inset:0;opacity:0.6;background-size:56px 4px;"></div>
  </div>
</section>
