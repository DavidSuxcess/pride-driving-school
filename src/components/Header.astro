---
import PrLion from './PrLion.astro';
---

<header
  id="top"
  class="sticky top-0 z-50 backdrop-blur-md border-b border-white/[0.08]"
  style="background:rgba(10,10,10,0.85);"
>
  <div class="max-w-[1760px] mx-auto flex items-center justify-between px-5 py-4 md:px-20 md:py-6">
    <a href="#top" class="flex items-center gap-2 md:gap-3 leading-none">
      <PrLion size={48} color="#E45400" />
      <div class="flex flex-col leading-none">
        <span class="font-display text-lg md:text-[22px] tracking-[0.04em] font-bold">ПРАЙД</span>
        <span class="font-mono text-[8px] md:text-[9px] tracking-[0.2em] text-white/50 mt-0.5">
          ШКОЛА ВОЖДЕНИЯ
        </span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-9 text-sm font-semibold">
      <a class="pr-link-u" href="#courses">Курсы</a>
      <a class="pr-link-u" href="#instructors">Инструкторы</a>
      <a class="pr-link-u" href="#reviews">Отзывы</a>
      <a class="pr-link-u" href="#faq">Вопросы</a>
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden md:block text-right">
        <div class="font-mono text-[10px] text-white/50 tracking-[0.16em]">ОТКРЫТО · ДО 21:00</div>
        <div class="font-bold text-[15px] mt-0.5">+7 (391) 234-56-78</div>
      </div>
      <button
        type="button"
        data-pr-enroll-trigger
        class="hidden md:inline-flex pr-btn-yellow"
        style="padding:12px 22px;font-size:12px;"
      >
        Записаться <span class="text-base">→</span>
      </button>
      <button
        type="button"
        data-pr-burger
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full bg-pr-yellow text-pr-black text-xl font-extrabold cursor-pointer border-0"
        aria-label="Открыть меню"
      >
        ≡
      </button>
    </div>
  </div>
</header>
