---
const items = [
  'КАТ. B · АВТОМАТ', 'КАТ. B · МЕХАНИКА', 'ИНДИВИДУАЛЬНЫЙ ГРАФИК',
  'СОПРОВОЖДЕНИЕ В ГИБДД', 'ЗАБИРАЕМ ИЗ ДОМА', 'ПЛАТЁЖ В РАССРОЧКУ',
  'ЛИЦЕНЗИЯ № 7167-Л', 'СВОЙ АВТОПАРК',
];
const track = [...items, ...items, ...items];
---

<div class="bg-pr-yellow text-pr-black overflow-hidden py-3 md:py-[18px] border-y border-pr-black">
  <div class="pr-marquee-track flex whitespace-nowrap w-max gap-6 md:gap-12">
    {track.map((t) => (
      <div class="flex items-center gap-6 md:gap-12 font-extrabold text-[13px] md:text-[22px] tracking-[0.04em]">
        <span>{t}</span>
        <span class="text-[11px] md:text-sm">✦</span>
      </div>
    ))}
  </div>
</div>
