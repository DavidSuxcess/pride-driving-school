---
const items = ['ЛИЦЕНЗИЯ № 7167-Л', 'РОСРЕЕСТР АВТОШКОЛ', 'ГИБДД РОССИИ', 'АВИТО · 5.0'];
const track = [...items, ...items, ...items];
---

<div class="bg-pr-black border-y border-white/[0.18] overflow-hidden py-3.5 md:py-6">
  <div class="pr-marquee-track-rev flex whitespace-nowrap w-max text-white/[0.65] gap-8 md:gap-20">
    {track.map((t) => (
      <div class="flex items-center gap-8 md:gap-20 font-mono text-[10px] md:text-sm tracking-[0.12em]">
        <span>{t}</span>
        <span class="text-pr-yellow">✦</span>
      </div>
    ))}
  </div>
</div>
