---
import faq from '../data/faq.json';
---

<section id="faq" class="px-5 py-[50px] md:px-20 md:py-40 bg-pr-paper text-[var(--pr-paper-ink)]">
  <div class="max-w-[1760px] mx-auto md:grid md:grid-cols-[420px_1fr] md:gap-40">
    <div class="mb-7 md:mb-0">
      <div class="pr-section-tag text-[10px] md:text-[11px]" style="color:#3a3a3a;">[05] ВОПРОСЫ</div>
      <h2 class="font-display uppercase text-[clamp(40px,12vw,52px)] md:text-[60px] mt-3.5 md:mt-6 text-pr-black leading-[0.95]">
        ЧАСТО<br />СПРАШИВАЮТ.
      </h2>
      <p class="mt-4 md:mt-8 text-sm md:text-base leading-[1.5] text-[#3a3a3a]">
        Если вашего вопроса нет — напишите в Telegram, отвечаем в течение 15 минут в рабочее время.
      </p>
      <button type="button" class="hidden md:inline-flex pr-btn-black mt-8">Написать в Telegram</button>
    </div>

    <div>
      {faq.map((it, i) => (
        <details
          class="pr-faq-item border-t border-black/[0.12] py-5 md:py-7"
          open={i === 0 ? true : undefined}
          style={i === faq.length - 1 ? 'border-bottom:1px solid rgba(0,0,0,0.12);' : undefined}
        >
          <summary>
            <span class="flex gap-3 md:gap-6 items-baseline">
              <span class="pr-num text-[9px] md:text-[11px]" style="color:#7a7a7a;">0{i + 1}</span>
              <span class="font-display uppercase text-lg md:text-[22px] text-pr-black leading-[1.1]">{it.q}</span>
            </span>
            <span class="pr-faq-toggle"></span>
          </summary>
          <p class="mt-3 md:mt-5 ml-7 md:ml-14 text-sm md:text-[17px] leading-[1.55] text-[#3a3a3a] max-w-[640px]">
            {it.a}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .pr-faq-item > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pr-faq-item > summary::-webkit-details-marker { display: none; }
  .pr-faq-toggle {
    width: 32px; height: 32px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.2);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 18px; font-weight: 300;
    transition: background 0.2s, border-color 0.2s;
  }
  @media (min-width: 768px) {
    .pr-faq-toggle { width: 42px; height: 42px; font-size: 22px; }
  }
  .pr-faq-toggle::before { content: '+'; line-height: 1; }
  .pr-faq-item[open] .pr-faq-toggle {
    background: var(--pr-yellow);
    border-color: var(--pr-yellow);
  }
  .pr-faq-item[open] .pr-faq-toggle::before { content: '–'; }
</style>
